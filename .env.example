# Copy this file to `.env` and paste your real values. `.env` is gitignored — never commit it.
# Get W&B key:  https://wandb.ai/authorize
# Get HF token: https://huggingface.co/settings/tokens  (create a WRITE token)

WANDB_API_KEY=your-wandb-key-here
HF_TOKEN=your-hf-write-token-here
WANDB_PROJECT=pretraining
